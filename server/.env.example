PORT=4000
MONGODB_URI=mongodb://localhost:27017/seller

# "keyword" is a deterministic local stand-in used for dev/tests; "llm" calls
# Azure OpenAI and requires the AZURE_OPENAI_* variables below.
ATTRIBUTE_EXTRACTOR=keyword
# "template" is a deterministic local stand-in used for dev/tests; "llm" calls
# Azure OpenAI and requires the AZURE_OPENAI_* variables below.
LISTING_GENERATOR=template

AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_TIMEOUT_MS=15000
